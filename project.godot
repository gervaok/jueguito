; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are loss-prone and hard to interpret.

config_version=5

[application]
config/name="Platformer Game"
config/description="A professional platformer game made with Godot 4.x"
run/main_scene="res://scenes/levels/level_1.tscn"
config/features=PackedStringArray("4.1")
config/icon="res://assets/icon.svg"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[input]
ui_left={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194319), Object(InputEventKey, "keycode": 65)]}
ui_right={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194321), Object(InputEventKey, "keycode": 68)]}
ui_up={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194320), Object(InputEventKey, "keycode": 87)]}
jump={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 32), Object(InputEventKey, "keycode": 87)]}

[physics]
2d/physics_engine="box2d"

[rendering]
textures/canvas_textures/default_texture_filter=0
